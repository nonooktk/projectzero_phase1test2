# ============================================================
# .env.example  （backend / scripts 共用）
# 使い方: cp .env.example .env  → 値を埋める
# .env はコミット禁止（.gitignore 済み想定）
# このファイルにはプレースホルダのみ書くこと（実キー・実パスワードは入れない）
# ============================================================

# ---------- Supabase ----------
# Supabase ダッシュボード → Project Settings → API Keys / Connect ボタン から取得
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJI...                # 公開可・将来の frontend 用
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...        # ★秘匿★ backend / seed_supabase.py 用
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxxxxxx.supabase.co:5432/postgres

# ---------- OpenAI ----------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini                         # 暫定。本番は Azure OpenAI に差し替え（仕様§3.3）

# ---------- ChromaDB（in-memory なので最小限） ----------
CHROMA_COLLECTION_NAME=project_zero
EMBEDDING_MODEL=all-MiniLM-L6-v2                 # dim=384

# ---------- FastAPI ----------
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000               # frontend の起動先

# ---------- Storage（Chroma snapshot バックアップ） ----------
SUPABASE_STORAGE_BUCKET=chroma-snapshots         # 事前に Storage に作成しておく
